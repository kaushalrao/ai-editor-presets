{
  "name": "ai-editor-presets",
  "version": "1.2.1",
  "description": "AI Standards: AI Unified Rule Architecture for Cursor, Copilot, & Antigravity.",
  "main": "index.js",
  "bin": {
    "ai-editor-presets": "./cli/index.js"
  },
  "scripts": {
    "test": "vitest run",
    "lint": "markdownlint '**/*.md' '**/*.mdc' --ignore node_modules",
    "lint:fix": "markdownlint '**/*.md' '**/*.mdc' --ignore node_modules --fix",
    "prepare": "husky",
    "release": "release-it"
  },
  "release-it": {
    "git": {
      "tagName": "v${version}",
      "commitMessage": "chore: release v${version}",
      "requireCleanWorkingDir": false,
      "requireUpstream": false
    },
    "github": {
      "release": true,
      "releaseName": "v${version}"
    },
    "npm": {
      "publish": false
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "infile": "RELEASE.md",
        "preset": "conventionalcommits"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kaushalrao/ai-editor-presets.git"
  },
  "bugs": {
    "url": "https://github.com/kaushalrao/ai-editor-presets/issues"
  },
  "homepage": "https://github.com/kaushalrao/ai-editor-presets#readme",
  "keywords": [
    "ai",
    "cursor",
    "copilot",
    "guidelines"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@release-it/conventional-changelog": "^10.0.6",
    "husky": "^9.1.7",
    "markdownlint-cli": "^0.48.0",
    "release-it": "^19.2.4",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "picocolors": "^1.1.1"
  }
}
