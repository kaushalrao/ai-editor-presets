{
  "name": "ai-editor-presets",
  "version": "1.1.1",
  "description": "AI Standards: AI Unified Rule Architecture for Cursor, Copilot, & Antigravity.",
  "main": "index.js",
  "bin": {
    "ai-editor-presets": "./cli/index.js"
  },
  "scripts": {
    "test": "node ./cli/index.js --editor=cursor --language=react",
    "lint": "markdownlint '**/*.md' '**/*.mdc' --ignore node_modules",
    "prepare": "husky",
    "lint:fix": "markdownlint '**/*.md' '**/*.mdc' --ignore node_modules --fix",
    "release": "standard-version --no-verify"
  },
  "standard-version": {
    "infile": "RELEASE.md"
  },
  "keywords": [
    "ai",
    "cursor",
    "copilot",
    "guidelines"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "husky": "^9.1.7",
    "markdownlint-cli": "^0.48.0",
    "standard-version": "^9.5.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "picocolors": "^1.1.1"
  }
}
